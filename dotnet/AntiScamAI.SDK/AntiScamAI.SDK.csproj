<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>AntiScamAI.SDK</RootNamespace>
    <AssemblyName>AntiScamAI.SDK</AssemblyName>
    <Version>1.0.0</Version>
    <Authors>AntiScam AI</Authors>
    <Description>AntiScam AI – AI-powered request inspection middleware for ASP.NET Core</Description>
    <PackageTags>antiscam;security;middleware;ai;fraud;phishing;aspnetcore</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/antiscamai/sdk.git</RepositoryUrl>
    <PackageProjectUrl>https://github.com/antiscamai/sdk</PackageProjectUrl>
    <PackageReleaseNotes>https://github.com/antiscamai/sdk/releases</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
